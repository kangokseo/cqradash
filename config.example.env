# ============================================================
#  KIS 수익률 대시보드 환경설정 템플릿
#  이 파일을 복사해 ".env" 로 저장한 뒤 값을 채워주세요.
#    (Windows PowerShell)  Copy-Item config.example.env .env
#  ⚠️ 실제 키/시크릿은 .env 에만 넣고, 이 템플릿 파일에는 넣지 마세요.
#  .env 는 절대 외부에 공유하지 마세요 (시크릿 포함).
# ============================================================

# 실전: https://openapi.koreainvestment.com:9443
# 모의: https://openapivts.koreainvestment.com:29443
KIS_BASE_URL=https://openapi.koreainvestment.com:9443

# ---- (선택) 전역 기본 키 ----
# 계좌 블록에 appkey/appsecret 를 적지 않은 경우 아래 값을 fallback 으로 사용.
# 모든 계좌가 각자 다른 키를 쓴다면 비워 두어도 됩니다.
# KIS_APP_KEY=
# KIS_APP_SECRET=

# ============================================================
#  계좌 목록
#  계좌별로 APP_KEY / APP_SECRET 가 다른 구조입니다.
#  한 줄당  ACCOUNTS__<인덱스>__<필드>
#    - appkey    : 해당 계좌의 APP_KEY
#    - appsecret : 해당 계좌의 APP_SECRET
#    - cano      : 종합계좌번호 앞 8자리
#    - acnt      : 계좌상품코드 뒤 2자리 (보통 01)
#    - name      : 대시보드 표시 별칭
#    - start     : 운용시작일 (YYYY-MM-DD) — CAGR 연환산 기준일
#    - setamt    : (선택) 설정금액(원금, 원 단위 정수). 대시보드 누적·CAGR 계산 기준.
#                  비워두면 해당 계좌 누적·CAGR 은 '—' 로 표시.
#    - kind      : (선택) 계좌유형. 비우면 주식위탁. 선물옵션 계좌는 futures 로 지정.
#                  예: ACCOUNTS__7__kind=futures  (상품코드 03 등 선물옵션 계좌)
#  계좌 추가 시 인덱스를 늘려 블록을 복사하세요. (삭제한 인덱스 재사용 금지)
# ============================================================

ACCOUNTS__1__appkey=계좌1_APP_KEY
ACCOUNTS__1__appsecret=계좌1_APP_SECRET
ACCOUNTS__1__cano=12345678
ACCOUNTS__1__acnt=01
ACCOUNTS__1__name=계좌1
ACCOUNTS__1__start=2024-01-02
ACCOUNTS__1__setamt=12000000

ACCOUNTS__2__appkey=계좌2_APP_KEY
ACCOUNTS__2__appsecret=계좌2_APP_SECRET
ACCOUNTS__2__cano=12345678
ACCOUNTS__2__acnt=01
ACCOUNTS__2__name=계좌2
ACCOUNTS__2__start=2024-03-15
ACCOUNTS__2__setamt=

# ---- 계좌 추가 시 아래처럼 새 인덱스(3, 4...) 블록을 복사 ----
# ACCOUNTS__3__appkey=계좌3_APP_KEY
# ACCOUNTS__3__appsecret=계좌3_APP_SECRET
# ACCOUNTS__3__cano=12345678
# ACCOUNTS__3__acnt=01
# ACCOUNTS__3__name=계좌3
# ACCOUNTS__3__start=2026-01-02

# ---- 벤치마크 ----
# 모든 계좌 공통 벤치마크. stooq 심볼 (S&P500 = ^spx)
BENCHMARK_SYMBOL=^spx
BENCHMARK_NAME=S&P 500
